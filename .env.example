# LINE Messaging API 設定
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_user_id_here

# 追蹤與通知參數設定
# 大盤當日下跌通知點數門檻 (預設 500)
DROP_THRESHOLD=500
# 每再下跌多少點通知一次 (預設 100)
DROP_STEP=100

# 技術指標進場訊號設定 (0: 關閉, 1: 開啟)
USE_KD_STRATEGY=1
USE_BOLLINGER_STRATEGY=1

# KD 策略參數
KD_PERIOD=9
KD_LIMIT=20

# 布林通道參數
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2.0
